{
  "singleQuote": true,
  "endOfLine": "auto",
  "trailingComma": "all",
  "tabWidth": 2,
  "jsxSingleQuote": true,
  "bracketSpacing": true,
  "plugins": ["prettier-plugin-tailwindcss"],
  "overrides": [
    {
      "files": "*.js",
      "options": {
        "semi": false,
        "singleQuote": true,
        "bracketSpacing": true
      }
    }
  ]
}
