## Complete Example

```typescript
import React from 'react';
import { Icon } from '@components';
import SkeletonBlock from '@components/Skeleton/ConceptReport/SkeletonBlock';

interface DataDisplayProps {
  uuid: string;
}

// Skeleton
const DataDisplaySkeleton: React.FC = () => (
  <div className='aucctus-bg-primary aucctus-border-secondary rounded-lg border p-6'>
    <div className='mb-4'>
      <SkeletonBlock className='h-6 w-48 mb-2' />
      <SkeletonBlock className='h-4 w-full' />
    </div>
    <div className='space-y-3'>
      {[...Array(3)].map((_, i) => (
        <SkeletonBlock key={i} className='h-20 w-full rounded' />
      ))}
    </div>
  </div>
);

// Empty State
const EmptyState: React.FC = () => (
  <div className='aucctus-bg-primary aucctus-border-secondary rounded-lg border p-12'>
    <div className='flex flex-col items-center justify-center gap-4 text-center'>
      <Icon variant='inbox-02' className='aucctus-stroke-tertiary h-12 w-12' />
      <div>
        <h3 className='aucctus-text-md-semibold aucctus-text-primary mb-2'>
          No Data Available
        </h3>
        <p className='aucctus-text-sm aucctus-text-secondary'>
          There is no data to display at this time.
        </p>
      </div>
    </div>
  </div>
);

// Error State
const ErrorState: React.FC<{ error?: Error; onRetry: () => void }> = ({ error, onRetry }) => (
  <div className='aucctus-bg-primary aucctus-border-secondary rounded-lg border p-12'>
    <div className='flex flex-col items-center justify-center gap-4 text-center'>
      <Icon variant='alert-circle' className='aucctus-stroke-error-primary h-12 w-12' />
      <div>
        <h3 className='aucctus-text-md-semibold aucctus-text-primary mb-2'>
          Error Loading Data
        </h3>
        <p className='aucctus-text-sm aucctus-text-secondary mb-4'>
          {error?.message || 'There was an error loading the data.'}
        </p>
        <button className='btn btn-primary btn-md' onClick={onRetry}>
          Try Again
        </button>
      </div>
    </div>
  </div>
);

// Main Component
const DataDisplay: React.FC<DataDisplayProps> = ({ uuid }) => {
  const { data, isLoading, isError, error, refetch } = useData(uuid);
  
  // Loading state
  if (isLoading) {
    return <DataDisplaySkeleton />;
  }
  
  // Error state
  if (isError) {
    return <ErrorState error={error} onRetry={refetch} />;
  }
  
  // Empty state
  if (!data || data.length === 0) {
    return <EmptyState />;
  }
  
  // Success state
  return (
    <div className='aucctus-bg-primary aucctus-border-secondary rounded-lg border p-6'>
      <h2 className='aucctus-text-xl-semibold aucctus-text-primary mb-4'>
        {data.title}
      </h2>
      <div className='space-y-4'>
        {data.items.map(item => (
          <div key={item.id} className='aucctus-bg-secondary rounded p-4'>
            {item.content}
          </div>
        ))}
      </div>
    </div>
  );
};

export default DataDisplay;
```

