## Complete Example: Monte Carlo Chart

```typescript
import React, { useState, useMemo } from 'react';
import { LineChart, Line, XAxis, YAxis, Tooltip, ResponsiveContainer, ReferenceLine } from 'recharts';
import { cn } from '@libs/utils/react';

const MonteCarloChart: React.FC<Props> = ({ initialInvestment = 250000, timeHorizon = 24 }) => {
  const [months, setMonths] = useState(timeHorizon);
  const [meanReturn, setMeanReturn] = useState(1.5);

  const chartData = useMemo(() => {
    return Array.from({ length: months }, (_, i) => ({
      month: i + 1,
      median: initialInvestment * (1 + meanReturn / 100) ** (i + 1),
      upper: initialInvestment * (1 + (meanReturn + 2) / 100) ** (i + 1),
      lower: initialInvestment * (1 + (meanReturn - 2) / 100) ** (i + 1),
    }));
  }, [months, initialInvestment, meanReturn]);

  return (
    <div className='aucctus-bg-primary aucctus-border-secondary rounded-lg border p-2'>
      <div className='p-4'>
        <div className='mb-3'>
          <h3 className='aucctus-header-xs-medium aucctus-text-primary'>
            Revenue Projection
          </h3>
          <p className='aucctus-text-sm aucctus-text-tertiary'>
            {months} month forecast
          </p>
        </div>

        <div className='h-72 w-full'>
          <ResponsiveContainer width='100%' height='100%'>
            <LineChart data={chartData} margin={{ top: 10, right: 20, left: 10, bottom: 10 }}>
              <XAxis
                dataKey='month'
                tickFormatter={(v) => `${v}m`}
                stroke='currentColor'
                opacity={0.5}
                tick={{ fontSize: 11 }}
                axisLine={{ stroke: 'currentColor', opacity: 0.2 }}
                tickLine={{ stroke: 'currentColor', opacity: 0.2 }}
              />
              <YAxis
                tickFormatter={(v) => `$${v / 1000}k`}
                stroke='currentColor'
                opacity={0.5}
                tick={{ fontSize: 11 }}
                axisLine={{ stroke: 'currentColor', opacity: 0.2 }}
                tickLine={{ stroke: 'currentColor', opacity: 0.2 }}
                width={50}
              />
              <Tooltip content={<CustomTooltip />} />
              <ReferenceLine
                y={initialInvestment}
                stroke='#9f7aea'
                strokeDasharray='3 3'
              />
              <Line type='monotone' dataKey='median' stroke='#7c3aed' strokeWidth={2.5} dot={false} />
              <Line type='monotone' dataKey='upper' stroke='#9f7aea' strokeWidth={1.5} dot={false} strokeOpacity={0.7} />
              <Line type='monotone' dataKey='lower' stroke='#9f7aea' strokeWidth={1.5} dot={false} strokeOpacity={0.7} />
            </LineChart>
          </ResponsiveContainer>
        </div>

        {/* Legend */}
        <div className='mt-4 grid grid-cols-3 gap-3'>
          <div className='flex items-center gap-2'>
            <div className='h-3 w-3 rounded-full bg-[#7c3aed]' />
            <span className='aucctus-text-xs aucctus-text-secondary'>Median</span>
          </div>
          <div className='flex items-center gap-2'>
            <div className='h-3 w-3 rounded-full bg-[#9f7aea]' />
            <span className='aucctus-text-xs aucctus-text-secondary'>Range</span>
          </div>
        </div>

        {/* Controls */}
        <div className='mt-6 flex gap-4'>
          <div className='flex-1'>
            <div className='mb-1 flex justify-between'>
              <span className='aucctus-text-xs aucctus-text-tertiary'>Months</span>
              <span className='aucctus-text-xs-semibold aucctus-text-primary'>{months}</span>
            </div>
            <input
              type='range'
              min='6'
              max='60'
              step='6'
              value={months}
              onChange={(e) => setMonths(parseInt(e.target.value))}
              className='aucctus-slider-brand aucctus-bg-brand-primary-alt h-1 w-full rounded'
            />
          </div>
        </div>
      </div>
    </div>
  );
};
```

