### Example: JobsToBeDone to CustomerJobs

#### BEFORE:
```tsx
import React, { useState } from 'react';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Briefcase, ArrowDown, Plus, Trash } from 'lucide-react';
import { toast } from 'sonner';

interface Job {
  id: number;
  text: string;
  priority?: number;
}

const sortJobs = (jobs: Job[]) => {
  return [...jobs].sort((a, b) => (a.priority || 0) - (b.priority || 0));
};

export function JobsToBeDone() {
  const [jobs, setJobs] = useState<Job[]>([
    { id: 1, text: 'Improve onboarding process', priority: 1 },
    { id: 2, text: 'Simplify checkout flow', priority: 2 },
    { id: 3, text: 'Add saved payment methods', priority: 3 },
  ]);
  const [isAdding, setIsAdding] = useState(false);
  const [newJobText, setNewJobText] = useState('');

  const handleAddJob = (e: React.FormEvent) => {
    e.preventDefault();
    if (!newJobText.trim()) return;

    const newJob: Job = {
      id: Date.now(),
      text: newJobText.trim(),
      priority: jobs.length + 1,
    };

    setJobs([...jobs, newJob]);
    setNewJobText('');
    setIsAdding(false);
    toast.success('Job added');
  };

  const handleRemoveJob = (id: number) => {
    setJobs(jobs.filter(job => job.id !== id));
    toast.success('Job removed');
  };

  const sortedJobs = sortJobs(jobs);

  const renderPriorityIndicator = (priority: number = 0) => {
    const priorityColor = priority === 1 ? 'text-red-500' : priority === 2 ? 'text-amber-500' : 'text-green-500';
    const priorityLine = priority === 1 ? 'bg-red-500' : priority === 2 ? 'bg-amber-500' : 'bg-green-500';
    
    return (
      <div className="flex flex-col items-center mr-3 pt-2">
        <span className={`text-xs font-semibold ${priorityColor}`}>{priority}</span>
        <div className={`w-0.5 h-12 mt-1 ${priorityLine}`}></div>
      </div>
    );
  };

  return (
    <Card className="h-fit">
      <CardHeader className="pb-3">
        <div className="flex items-center justify-between">
          <CardTitle className="text-lg flex items-center gap-2">
            <Briefcase className="h-5 w-5 text-primary" />
            Jobs to be Done
          </CardTitle>
          <Button 
            variant="ghost" 
            size="icon"
            className="h-8 w-8"
            onClick={() => setIsAdding(true)}
            disabled={isAdding}
          >
            <Plus className="h-4 w-4" />
          </Button>
        </div>
      </CardHeader>
      <CardContent className="pt-0 pb-3">
        {isAdding ? (
          <form onSubmit={handleAddJob} className="mb-4">
            <Input
              value={newJobText}
              onChange={(e) => setNewJobText(e.target.value)}
              placeholder="Add a new job..."
              className="mb-2"
            />
            <div className="flex justify-end gap-2">
              <Button variant="outline" size="sm" onClick={() => setIsAdding(false)}>
                Cancel
              </Button>
              <Button type="submit" size="sm">
                Add Job
              </Button>
            </div>
          </form>
        ) : null}
        
        <div className="space-y-3">
          {sortedJobs.map((job) => (
            <div key={job.id} className="flex items-start border rounded-md p-2">
              {renderPriorityIndicator(job.priority)}
              <div className="flex-1">
                <p className="text-sm">{job.text}</p>
              </div>
              <Button 
                variant="ghost" 
                size="icon" 
                className="h-8 w-8 text-muted-foreground"
                onClick={() => handleRemoveJob(job.id)}
              >
                <Trash className="h-4 w-4" />
              </Button>
            </div>
          ))}
        </div>
      </CardContent>
    </Card>
  );
}
```

#### AFTER:

```tsx
import React, { useState, useMemo, useCallback } from 'react';
import { Icon, toast, SectionHeader } from '@components';

interface MockJob {
  id: string;
  text: string;
  priority?: number;
  createdAt: string;
}

// Extracted component for priority indicator
const PriorityIndicator = ({ priority }: { priority?: number }) => {
  const getPriorityColor = () => {
    if (priority === 1) return { 
      text: 'aucctus-text-error-primary', 
      line: 'bg-red-500' 
    };
    if (priority === 2) return { 
      text: 'aucctus-text-warning-primary', 
      line: 'bg-amber-500' 
    };
    return { 
      text: 'aucctus-text-success-primary', 
      line: 'bg-green-500' 
    };
  };
  
  const { text, line } = getPriorityColor();
  
  return (
    <div className="flex flex-col items-center mr-3 pt-2">
      <span className={`aucctus-text-xs-semibold ${text}`}>{priority}</span>
      <div className={`w-0.5 h-12 mt-1 ${line}`}></div>
    </div>
  );
};

const CustomerJobs = () => {
  // Initial mock data
  const initialMockJobs: MockJob[] = [
    { 
      id: '1', 
      text: 'Improve onboarding process', 
      priority: 1, 
      createdAt: new Date().toISOString() 
    },
    { 
      id: '2', 
      text: 'Simplify checkout flow', 
      priority: 2, 
      createdAt: new Date().toISOString() 
    },
    { 
      id: '3', 
      text: 'Add saved payment methods', 
      priority: 3, 
      createdAt: new Date().toISOString() 
    },
  ];
  
  const [mockJobs, setMockJobs] = useState<MockJob[]>(initialMockJobs);
  const [isAdding, setIsAdding] = useState(false);
  const [newJobText, setNewJobText] = useState('');
  
  // Sort jobs by priority using useMemo
  const sortedJobs = useMemo(
    () => [...mockJobs].sort((a, b) => (a.priority || 0) - (b.priority || 0)),
    [mockJobs],
  );
  
  // Use useCallback for event handlers
  const handleStartAdding = useCallback(() => {
    setIsAdding(true);
  }, []);
  
  const handleCancel = useCallback(() => {
    setIsAdding(false);
    setNewJobText('');
  }, []);
  
  const handleAddJob = useCallback((e: React.FormEvent) => {
    e.preventDefault();
    if (!newJobText.trim()) return;
    
    const newJob: MockJob = {
      id: Date.now().toString(),
      text: newJobText.trim(),
      priority: mockJobs.length + 1,
      createdAt: new Date().toISOString(),
    };
    
    setMockJobs([...mockJobs, newJob]);
    setNewJobText('');
    setIsAdding(false);
    toast.success('Job added');
  }, [mockJobs, newJobText]);
  
  const handleDelete = useCallback((id: string) => {
    setMockJobs(mockJobs.filter(job => job.id !== id));
    toast.success('Job removed');
  }, [mockJobs]);
  
  return (
    <div className="aucctus-bg-primary aucctus-border-secondary h-fit rounded-lg border shadow-sm">
      <SectionHeader
        icon="briefcase"
        iconClass="aucctus-stroke-primary"
        iconBgClass="aucctus-bg-primary aucctus-border-secondary"
        title="Customer Jobs"
        noDivider={true}
        rightAction={
          <button
            className="aucctus-bg-secondary-hover flex items-center justify-center rounded-full p-2 transition-colors disabled:opacity-50"
            aria-label="Add job"
            onClick={handleStartAdding}
            disabled={isAdding}
          >
            <Icon variant="plus" className="aucctus-stroke-primary" height={16} width={16} />
          </button>
        }
      />
      <div className="px-4 py-2">
        {isAdding ? (
          <form onSubmit={handleAddJob} className="mb-4">
            <input
              value={newJobText}
              onChange={(e) => setNewJobText(e.target.value)}
              placeholder="Add a new job..."
              className="aucctus-bg-primary aucctus-border-secondary aucctus-text-primary p-2 rounded-md border w-full mb-2"
            />
            <div className="flex justify-end gap-2">
              <button 
                type="button" 
                className="btn btn-light btn-sm" 
                onClick={handleCancel}
              >
                Cancel
              </button>
              <button type="submit" className="btn btn-primary btn-sm">
                Add Job
              </button>
            </div>
          </form>
        ) : null}
        
        <div className="space-y-3">
          {sortedJobs.map((job) => (
            <div key={job.id} className="aucctus-bg-primary aucctus-border-secondary flex items-start rounded-md border p-2">
              <PriorityIndicator priority={job.priority} />
              <div className="flex-1">
                <p className="aucctus-text-primary aucctus-text-sm">{job.text}</p>
              </div>
              <button 
                className="aucctus-bg-secondary-hover rounded-full p-2 transition-colors"
                onClick={() => handleDelete(job.id)}
                aria-label="Delete job"
              >
                <Icon variant="trash" className="aucctus-stroke-error-primary" height={16} width={16} />
              </button>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
};

export default React.memo(CustomerJobs);
```

This transformation example demonstrates:

1. **Component Structure Changes**:
   - Card → div with Aucctus theme classes
   - CardHeader → SectionHeader component
   - CardTitle → SectionHeader title prop
   - Button → native button with Aucctus classes
   - Extracted PriorityIndicator into its own component

2. **Styling Transformations**:
   - Replaced Tailwind classes with Aucctus theme classes
   - Added proper button styling with btn classes
   - Applied proper text styling with aucctus-text-* classes
   - Added appropriate icon styling with aucctus-stroke-* classes

3. **State Management Improvements**:
   - Used string IDs instead of number IDs
   - Added createdAt timestamp field
   - Implemented useMemo for sorting
   - Added useCallback for event handlers
   - Used proper immutable state updates

4. **Performance Optimizations**:
   - Added React.memo to the entire component
   - Applied proper dependency arrays to hooks
   - Used memoization for derived data

5. **Accessibility Enhancements**:
   - Added aria-label attributes to icon buttons
   - Maintained semantic HTML structure
   - Provided proper keyboard navigation

By following this transformation pattern, the component has been successfully ported from the external implementation to an Aucctus-compliant internal component.

