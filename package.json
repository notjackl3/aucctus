{
  "name": "aucctus",
  "private": true,
  "version": "2.3.0",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "start:dev": "npm run dev",
    "build": "vite build",
    "build:debug": "vite build --debug",
    "preview": "NODE_ENV=production vite preview",
    "format": "prettier --config ./.prettierrc --write .",
    "lint": "eslint . --max-warnings=0 --ignore-pattern 'lovable/**'",
    "prettier-check": "prettier --config ./.prettierrc --check . --ignore-path .prettierignore --ignore-path-pattern 'lovable/**'",
    "type-check": "tsc",
    "lint-staged": "lint-staged --config lint-staged.js",
    "test": "vitest --run",
    "prepare": "husky",
    "generate-sprite-svg": "svg-sprite --config=svg-sprite.config.json icons/*.svg",
    "generate-icon-types": "node scripts/generate-icon-types.js",
    "icon-hash-buster": "node scripts/modify-icon-hash.js",
    "generate-sprite": "npm run generate-sprite-svg && npm run generate-icon-types && npm run icon-hash-buster",
    "analyze": "ANALYZE=true NODE_ENV=production vite build",
    "analyze-bundle": "NODE_ENV=production npx vite-bundle-visualizer -c vite.config.mts --open",
    "check-deps": "npx depcheck"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.38.0",
    "@dhmk/zustand-lens": "^5.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@floating-ui/react-dom": "^2.1.1",
    "@marsidev/react-turnstile": "^1.4.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.8",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-spring/web": "^9.7.3",
    "@sentry/react": "^8.37.1",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tanstack/react-table": "^8.10.7",
    "@types/crypto-js": "^4.2.2",
    "abort-controller": "^3.0.0",
    "axios": "^1.6.1",
    "bootstrap": "^5.3.3",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "framer-motion": "^12.23.25",
    "immer": "^10.1.1",
    "jwt-decode": "^4.0.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.562.0",
    "react": "^18.2.0",
    "react-click-away-listener": "^2.2.4",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.3",
    "react-query": "^3.39.3",
    "react-router-dom": "^6.16.0",
    "react-select": "^5.8.0",
    "react-spring": "^9.7.4",
    "react-toastify": "^10.0.4",
    "react-use": "^17.5.0",
    "recharts": "^2.15.3",
    "resize-observer-polyfill": "^1.5.1",
    "scss": "^0.2.4",
    "tailwind-merge": "^2.5.2",
    "uuid": "^11.1.0",
    "vite-plugin-checker": "^0.9.1",
    "vite-plugin-svgr": "^4.1.0",
    "zustand": "^5.0.3",
    "zustand-multi-persist": "^0.1.4"
  },
  "overrides": {
    "fast-xml-parser": "^5.3.4"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^2.22.6",
    "@types/jwt-decode": "^2.2.1",
    "@types/node": "^24.3.0",
    "@types/postcss-import": "^14.0.3",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "@types/react-scroll-to-bottom": "^4.2.5",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.19",
    "cheerio": "^1.0.0-rc.12",
    "cssnano": "^6.1.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.11",
    "jsdom": "^21.1.0",
    "lint-staged": "^15.2.2",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "sass": "^1.72.0",
    "svg-sprite": "^2.0.4",
    "tailwindcss": "^3.4.3",
    "terser": "^5.30.3",
    "tsc-files": "^1.1.4",
    "typescript": "5.1",
    "vite": "^6.2.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-imagemin": "^0.1.0",
    "vitest": "^3.0.7"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "plugins": [
      "prettier"
    ],
    "rules": {
      "react/jsx-no-target-blank": "off"
    }
  }
}
